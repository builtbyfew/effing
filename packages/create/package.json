{
  "name": "@effing/create",
  "version": "0.38.0",
  "description": "Create a new Effing project",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/builtbyfew/effing.git",
    "directory": "packages/create"
  },
  "type": "module",
  "bin": "./dist/index.js",
  "files": [
    "dist",
    "template"
  ],
  "scripts": {
    "prebuild": "node scripts/copy-template.js",
    "build": "tsup",
    "test": "vitest run --exclude '**/*.integration.test.ts' --passWithNoTests",
    "test:integration": "vitest run integration",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "effing",
    "create",
    "scaffold",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
