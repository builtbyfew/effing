{
  "name": "@effing/effie-preview",
  "version": "0.37.0",
  "description": "Preview components for Effie video compositions",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effing/annie-player": "workspace:*",
    "@effing/effie": "workspace:*"
  },
  "devDependencies": {
    "@effing/ffs": "workspace:*",
    "@types/react": "^19.0.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "effie",
    "preview",
    "video",
    "react"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
