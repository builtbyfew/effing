{
  "name": "@effing/serde",
  "version": "0.7.3",
  "description": "URL-safe serialization with compression and HMAC signing",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "serialization",
    "base64",
    "hmac",
    "url-safe"
  ],
  "license": "O'Saasy",
  "publishConfig": {
    "access": "public"
  }
}
