{
  "name": "@effing/annie-player",
  "version": "0.30.1",
  "description": "Annie animation player that runs in the browser",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@andrewbranch/untar.js": "^1.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "animation",
    "player",
    "annie",
    "react"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
