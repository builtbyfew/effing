{
  "name": "@effing/ffmpeg",
  "version": "0.31.1",
  "description": "FFmpeg binary downloader for Effing",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "install.mjs"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "install": "node install.mjs"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "keywords": [
    "ffmpeg",
    "binary"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
