{
  "name": "@effing/canvas",
  "version": "0.37.0",
  "description": "Low-level canvas rendering for JSX and Lottie using @napi-rs/canvas (Skia)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/builtbyfew/effing.git",
    "directory": "packages/canvas"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:comparison": "vitest run comparison/",
    "bench": "tsx benchmark/bench.tsx"
  },
  "dependencies": {
    "css-background-parser": "^0.1.0",
    "css-box-shadow": "^1.0.0-3",
    "css-gradient-parser": "^0.0.17",
    "css-to-react-native": "^3.0.0",
    "linebreak": "^1.1.0",
    "parse-css-color": "^0.2.1",
    "postcss-value-parser": "^4.2.0",
    "yoga-layout": "^3.2.1"
  },
  "devDependencies": {
    "@effing/tween": "workspace:*",
    "@resvg/resvg-js": "^2.6.2",
    "@types/react": "^19.0.0",
    "mitata": "^1.0.34",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "satori": "^0.24.1",
    "tsup": "catalog:",
    "tsx": "^4.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@napi-rs/canvas": ">=0.1.50",
    "csstype": ">=3.2.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "csstype": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "canvas",
    "skia",
    "jsx",
    "lottie",
    "render",
    "png"
