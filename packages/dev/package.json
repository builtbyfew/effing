{
  "name": "@effing/dev",
  "version": "0.38.0",
  "description": "Dev server and build tooling for Effing projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/builtbyfew/effing.git",
    "directory": "packages/dev"
  },
  "type": "module",
  "bin": {
    "effing": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsup && react-router build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@effing/annie-player": "workspace:*",
    "@effing/effie": "workspace:*",
    "@effing/effie-preview": "workspace:*",
    "@effing/fn": "workspace:*",
    "@effing/serde": "workspace:*",
    "@react-router/dev": "^7.11.0",
    "@react-router/node": "^7.11.0",
    "commander": "^13.0.0",
    "esbuild": "^0.28.0",
    "isbot": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.11.0",
    "tiny-invariant": "^1.3.1",
    "tinyglobby": "^0.2.15",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^4.3.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "effing",
    "dev",
    "cli"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
