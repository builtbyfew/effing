{
  "name": "@effing/fn",
  "version": "0.35.3",
  "description": "Effing function runtime — pluggable module loading and URL building",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effing/annie": "workspace:*",
    "@effing/effie": "workspace:*",
    "@effing/serde": "workspace:*"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "keywords": [
    "effing",
    "functions",
    "runtime"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
