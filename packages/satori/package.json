{
  "name": "@effing/satori",
  "version": "0.7.3",
  "description": "Render JSX to PNG using Satori with emoji support",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "satori": "^0.12.2"
  },
  "devDependencies": {
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "keywords": [
    "satori",
    "svg",
    "png",
    "jsx",
    "emoji"
  ],
  "license": "O'Saasy",
  "publishConfig": {
    "access": "public"
  }
}
