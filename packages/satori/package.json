{
  "name": "@effing/satori",
  "version": "0.15.0",
  "description": "Render JSX to PNG using Satori with emoji support",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./elements": {
      "types": "./dist/elements/index.d.ts",
      "import": "./dist/elements/index.js"
    },
    "./pool": {
      "types": "./dist/pool/index.d.ts",
      "import": "./dist/pool/index.js"
    },
    "./worker": {
      "import": "./dist/worker/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "satori": ">=0.10.0 <1.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "keywords": [
    "satori",
    "svg",
    "png",
    "jsx",
    "emoji",
    "worker",
    "pool"
  ],
  "license": "O'Saasy",
  "publishConfig": {
    "access": "public"
  }
}
